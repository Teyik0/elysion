{
  "name": "@teyik0/furin",
  "version": "0.2.0-beta.1",
  "description": "React meta-framework powered by Elysia and Bun with file-based routing, SSR, SSG, and ISR.",
  "license": "MIT",
  "author": "teyik0",
  "sideEffects": false,
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "react",
    "furin",
    "framework",
    "elysia",
    "bun",
    "ssr",
    "ssg",
    "routing",
    "file-based-routing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teyik0/furin.git"
  },
  "bugs": {
    "url": "https://github.com/teyik0/furin/issues"
  },
  "homepage": "https://github.com/teyik0/furin#readme",
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/furin.js",
  "module": "./dist/furin.js",
  "types": "./dist/furin.d.ts",
  "bin": {
    "furin": "./src/cli/index.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/furin.d.ts",
      "bun": "./src/furin.ts",
      "import": "./dist/furin.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "bun": "./src/client.ts",
      "import": "./dist/client.js"
    },
    "./build": {
      "types": "./dist/build/index.d.ts",
      "bun": "./src/build/index.ts",
      "import": "./dist/build/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "bun": "./src/config.ts",
      "import": "./dist/config.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "bun": "./src/router.ts",
      "import": "./dist/router.js"
    },
    "./strip-plugin": {
      "types": "./dist/plugin/index.d.ts",
      "bun": "./src/plugin/index.ts",
      "import": "./dist/plugin/index.js"
    },
    "./link": {
      "types": "./dist/link.d.ts",
      "bun": "./src/link.tsx",
      "import": "./dist/link.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "bun": "./src/env.d.ts"
    }
  },
  "scripts": {
    "fix": "ultracite fix",
    "test": "bun test --parallel --isolate --bail --preload ../../tests/setup.ts",
    "test:dev": "bun test --changed --parallel --isolate --bail --preload ../../tests/setup.ts",
    "tscheck": "tsc --noEmit",
    "build": "bun run build.ts"
  },
  "dependencies": {
    "@elysiajs/static": "^1.4.10",
    "magic-string": "^0.30.21",
    "seroval": "^1.5.4",
    "yuku-parser": "^0.5.0"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "expect-type": "^1.3.0"
  },
  "peerDependencies": {
    "elysia": "catalog:",
    "evlog": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
