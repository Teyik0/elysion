{
  "name": "@teyik0/furin/root",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "fix": "ultracite fix",
    "dev": "bun run --parallel --filter '*' --if-present dev",
    "test": "bun run --parallel --filter '*' test",
    "test:dev": "bun run --parallel --filter '*' test:dev",
    "tscheck": "bun run --parallel --filter '*' tscheck",
    "build": "bun run --filter '@teyik0/furin' build && bun run --parallel --filter '!@teyik0/furin' build",
    "start": "bun run --parallel --filter '*' --if-present start",
    "cache:clean": "rm -rf node_modules examples/*/node_modules packages/*/node_modules && bun pm cache rm",
    "iup": "bun update --interactive --recursive",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/bun": "^1.3.13",
    "knip": "^6.11.0",
    "lefthook": "^2.1.6",
    "react-doctor": "^0.0.47",
    "typescript": "^6.0.3",
    "ultracite": "7.6.2"
  },
  "catalog": {
    "elysia": "^1.4.28",
    "evlog": "^2.14.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
