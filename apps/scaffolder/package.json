{
  "name": "create-furin",
  "version": "0.3.3",
  "description": "Official scaffolder for Furin — the React meta-framework on Elysia + Bun",
  "type": "module",
  "bin": {
    "create-furin": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "fix": "ultracite fix",
    "test": "bun test --parallel --isolate --bail",
    "test:dev": "bun test --changed --parallel --isolate --bail",
    "tscheck": "tsc --noEmit",
    "build": "bun build src/index.ts --target bun --outdir dist --external ejs"
  },
  "dependencies": {
    "ejs": "^5.0.2"
  },
  "devDependencies": {
    "@clack/prompts": "^1.3.0",
    "@types/ejs": "^3.1.5",
    "picocolors": "^1.1.1"
  }
}
