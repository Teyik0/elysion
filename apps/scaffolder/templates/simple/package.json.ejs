{
  "name": "<%= projectNameKebab %>",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "fix": "ultracite fix",
    "tscheck": "tsc --noEmit",
    "dev": "bun --hot src/server.ts",
    "build": "furin build --target bun --compile embed",
    "start": "./.furin/build/bun/server"
  },
  "dependencies": {
    "@teyik0/furin": "<%= versions['@teyik0/furin'] %>",
    "bun-plugin-tailwind": "<%= versions['bun-plugin-tailwind'] %>",
    "elysia": "<%= versions['elysia'] %>",
    "evlog": "<%= versions['evlog'] %>",
    "react": "<%= versions['react'] %>",
    "react-dom": "<%= versions['react-dom'] %>"
  },
  "devDependencies": {
    "@biomejs/biome": "<%= versions['@biomejs/biome'] %>",
    "@types/bun": "<%= versions['@types/bun'] %>",
    "@types/react": "<%= versions['@types/react'] %>",
    "@types/react-dom": "<%= versions['@types/react-dom'] %>",
    "tailwindcss": "<%= versions['tailwindcss'] %>",
    "typescript": "<%= versions['typescript'] %>",
    "ultracite": "<%= versions['ultracite'] %>"
  }
}
